# Copy to .env and fill in. Never commit .env.
# Generate secrets with: mix phx.gen.secret  (or: openssl rand -base64 64)

# --- Database ---
POSTGRES_DB=zeval_dev
POSTGRES_USER=zeval
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://zeval:change-me@db/zeval_dev
# Set to "true" in production to require verified TLS to Postgres.
DATABASE_SSL=false
POOL_SIZE=10

# --- Phoenix / session secrets (REQUIRED in prod) ---
SECRET_KEY_BASE=
SESSION_SIGNING_SALT=
SESSION_ENCRYPTION_SALT=
LIVE_VIEW_SIGNING_SALT=
PHX_HOST=localhost
# Comma-separated additional allowed websocket origins, if any.
EXTRA_ALLOWED_ORIGINS=

# --- Optional privileged endpoints ---
# Bearer token required to scrape GET /metrics. Unset => endpoint disabled.
METRICS_TOKEN=

# --- Admin seed (optional, used by priv/repo/seeds.exs) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Misc ---
ENGINE_PORT=4000
LOG_LEVEL=info
