<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Zeval Engine | High-Precision Graph Authorization</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;family=JetBrains+Mono:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-low": "#0a0a0a",
                        "emerald-success": "#10b981",
                        "on-error-container": "#ffdad6",
                        "on-secondary-fixed": "#1c1b1b",
                        "surface": "#0a0a0a",
                        "on-primary-fixed-variant": "#474646",
                        "inverse-on-surface": "#303031",
                        "tertiary-fixed": "#e4e2e1",
                        "surface-container-high": "#111111",
                        "on-tertiary-fixed": "#1b1c1c",
                        "on-primary": "#313030",
                        "on-tertiary": "#303030",
                        "error": "#ffb4ab",
                        "secondary-fixed-dim": "#c8c6c5",
                        "tertiary": "#c8c6c5",
                        "primary-fixed": "#e5e2e1",
                        "secondary-container": "#1a1a1a",
                        "primary": "#c9c6c5",
                        "surface-variant": "#1a1a1a",
                        "on-tertiary-fixed-variant": "#474746",
                        "primary-container": "#000000",
                        "surface-container": "#0d0d0d",
                        "on-primary-fixed": "#1c1b1b",
                        "on-surface": "#e3e2e2",
                        "tertiary-container": "#000000",
                        "error-container": "#93000a",
                        "background": "#050505",
                        "text-secondary": "#737373",
                        "surface-container-highest": "#1a1a1a",
                        "primary-fixed-dim": "#c9c6c5",
                        "on-background": "#e3e2e2",
                        "border-subtle": "#1a1a1a",
                        "on-secondary": "#313030",
                        "surface-container-lowest": "#000000",
                        "on-secondary-container": "#b7b4b4",
                        "on-tertiary-container": "#7a7979",
                        "on-error": "#690005",
                        "outline": "#404040",
                        "inverse-surface": "#e3e2e2",
                        "on-surface-variant": "#a3a3a3",
                        "text-primary": "#ffffff",
                        "surface-tint": "#c9c6c5",
                        "ruby-error": "#e11d48",
                        "secondary": "#c8c6c5",
                        "tertiary-fixed-dim": "#c8c6c5",
                        "surface-dim": "#050505",
                        "surface-bright": "#1a1a1a",
                        "secondary-fixed": "#e5e2e1",
                        "text-muted": "#404040",
                        "on-secondary-fixed-variant": "#474746",
                        "inverse-primary": "#5f5e5e",
                        "outline-variant": "#1a1a1a",
                        "on-primary-container": "#7b7979"
                    },
                    "borderRadius": {
                        "DEFAULT": "0px",
                        "lg": "0px",
                        "xl": "0px",
                        "full": "9999px"
                    },
                    "spacing": {
                        "container-max": "1440px",
                        "stack-xs": "0.25rem",
                        "stack-md": "1rem",
                        "stack-lg": "1.5rem",
                        "gutter": "1rem",
                        "margin-page": "2rem",
                        "stack-sm": "0.5rem"
                    },
                    "fontFamily": {
                        "headline-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        "code-block": ["JetBrains Mono"],
                        "body-md": ["Inter"],
                        "label-mono": ["JetBrains Mono"],
                        "body-sm": ["Inter"]
                    },
                    "fontSize": {
                        "headline-md": ["20px", {"lineHeight": "28px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "headline-lg": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.04em", "fontWeight": "700"}],
                        "code-block": ["13px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "label-mono": ["11px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500"}],
                        "body-sm": ["12px", {"lineHeight": "18px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
<style>
        body {
            background-color: #050505;
            color: #e3e2e2;
            -webkit-font-smoothing: antialiased;
        }
        .technical-grid {
            background-image:
                linear-gradient(to right, #1a1a1a 1px, transparent 1px),
                linear-gradient(to bottom, #1a1a1a 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .module-block {
            border: 1px solid #1a1a1a;
            background: #0d0d0d;
            position: relative;
        }
        .module-block::before {
            content: '';
            position: absolute;
            top: -1px;
            left: -1px;
            width: 4px;
            height: 4px;
            background: #10b981;
        }
        .tracking-tight-custom {
            letter-spacing: -0.05em;
        }
        .mono-label {
            font-family: 'JetBrains Mono', monospace;
            text-transform: uppercase;
            font-size: 10px;
            letter-spacing: 0.1em;
        }
    </style>
</head>
<body class="font-body-md text-body-md overflow-x-hidden selection:bg-emerald-success selection:text-black">
  <!-- Header -->
  <header class="w-full h-14 sticky top-0 z-50 bg-background border-b border-outline-variant" style="backdrop-filter: blur(12px);">
    <div class="flex items-center justify-between px-margin-page w-full h-full max-w-container-max mx-auto">
      <div class="flex items-center gap-stack-md">
        <svg width="120" height="28" viewBox="0 0 400 100" fill="none" class="h-5 w-auto">
          <text x="0" y="70" font-family="Inter, sans-serif" font-weight="900" font-size="64" letter-spacing="0.1em" fill="#ffffff">ZEVAL</text>
          <rect x="300" y="45" width="40" height="4" fill="#10b981"/>
        </svg>
      </div>

      <div class="flex items-center gap-4">
        <span class="mono-label text-emerald-success hidden sm:block">Status: Operational</span>
        <a href="/dashboard/signup" class="bg-white text-black px-4 py-1.5 mono-label font-bold hover:bg-emerald-success transition-all">Init_System</a>
      </div>
    </div>
  </header>

  <main class="relative technical-grid min-h-screen">
    <!-- Hero -->
    <section class="relative pt-32 pb-40 px-margin-page border-b border-outline-variant">
      <div class="max-w-container-max mx-auto grid grid-cols-12 gap-gutter">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-3 px-3 py-1 bg-surface-container border border-outline-variant mb-12">
            <span class="w-1.5 h-1.5 bg-emerald-success"></span>
            <span class="mono-label text-emerald-success">Build_v1.2.4_Stable</span>
          </div>
          <h1 class="font-headline-lg text-6xl md:text-8xl font-extrabold text-text-primary tracking-tight-custom mb-12 leading-[0.9]">
            Recursive<br/>Graph<br/><span class="text-emerald-success">Authorization.</span>
          </h1>
          <p class="font-body-md text-lg text-text-secondary max-w-xl mb-12 border-l border-emerald-success pl-6">
            A high-density engine for Relationship-Based Access Control (ReBAC). Engineered for complex object-to-object permission logic and global graph consistency — the same model used by Google Drive, Calendar, and Cloud IAM.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/dashboard/signup" class="bg-emerald-success text-black px-8 py-4 mono-label font-bold flex items-center gap-3 hover:brightness-110 transition-all">
              EXECUTE_START <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/dashboard/docs" class="border border-outline-variant bg-surface/50 text-text-primary px-8 py-4 mono-label font-bold flex items-center gap-3 hover:bg-surface-container-highest transition-all">
              VIEW_SPEC <span class="material-symbols-outlined text-sm">terminal</span>
            </a>
          </div>
        </div>
        <div class="col-span-12 lg:col-span-5 mt-20 lg:mt-0 flex flex-col justify-end">
          <div class="module-block p-6" style="border-color: rgba(16, 185, 129, 0.2);">
            <div class="flex justify-between items-center mb-6 border-b border-outline-variant pb-2">
              <span class="mono-label text-text-muted">Core_Logic_Stream</span>
              <span class="text-[10px] text-emerald-success animate-pulse">● LIVE</span>
            </div>
            <div class="space-y-4 font-code-block text-xs leading-relaxed text-text-secondary">
              <div class="flex gap-4">
                <span class="text-text-muted shrink-0">0x01</span>
                <p><span class="text-emerald-success">CHECK</span> (user:821, view, doc:alpha)</p>
              </div>
              <div class="flex gap-4">
                <span class="text-text-muted shrink-0">0x02</span>
                <p>↳ Resolving <span class="text-text-primary">parent_org</span> relations...</p>
              </div>
              <div class="flex gap-4">
                <span class="text-text-muted shrink-0">0x03</span>
                <p>↳ Found path via <span class="text-text-primary">inherited_editor</span></p>
              </div>
              <div class="flex gap-4 border-t border-outline-variant pt-2">
                <span class="text-text-muted shrink-0">0x04</span>
                <p class="text-emerald-success font-bold">RESULT: GRANTED</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Specs Bar -->
    <section class="border-b border-outline-variant bg-black">
      <div class="max-w-container-max mx-auto flex flex-wrap divide-x divide-outline-variant">
        <div class="flex-1 min-w-[200px] p-8">
          <span class="mono-label text-text-muted block mb-4">Precision_Index</span>
          <span class="font-headline-lg text-4xl text-text-primary tracking-tight-custom">1.0000</span>
        </div>
        <div class="flex-1 min-w-[200px] p-8">
          <span class="mono-label text-text-muted block mb-4">Graph_Depth</span>
          <span class="font-headline-lg text-4xl text-text-primary tracking-tight-custom">∞ DEPTH</span>
        </div>
        <div class="flex-1 min-w-[200px] p-8">
          <span class="mono-label text-text-muted block mb-4">Tuple_Storage</span>
          <span class="font-headline-lg text-4xl text-text-primary tracking-tight-custom">DISTRIBUTED</span>
        </div>
        <div class="flex-1 min-w-[200px] p-8">
          <span class="mono-label text-text-muted block mb-4">Auth_Model</span>
          <span class="font-headline-lg text-4xl text-text-primary tracking-tight-custom">REBAC/ZNZ</span>
        </div>
      </div>
    </section>

    <!-- Modules -->
    <section class="py-32 px-margin-page max-w-container-max mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-20">
        <div>
          <span class="mono-label text-emerald-success block mb-4">System_Capabilities</span>
          <h3 class="font-headline-lg text-5xl font-extrabold tracking-tight-custom">Technical Modules.</h3>
        </div>
        <p class="mono-label text-text-muted max-w-xs text-right">00_ARCHITECTURE_OVERVIEW // REBAC_CORE_ENGINE</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-t border-l border-outline-variant">
        <div class="p-10 border-r border-b border-outline-variant group hover:bg-surface-container transition-colors">
          <div class="mb-12 flex justify-between items-start">
            <span class="material-symbols-outlined text-3xl text-emerald-success">hub</span>
            <span class="mono-label text-text-muted">MOD_01</span>
          </div>
          <h4 class="mono-label text-lg text-text-primary mb-4">Graph_Traversal</h4>
          <p class="text-sm text-text-secondary leading-relaxed">Recursive resolution of permission sets across complex object hierarchies. Supports deep nesting, transitive closure, and multi-hop relationship chains.</p>
        </div>
        <div class="p-10 border-r border-b border-outline-variant group hover:bg-surface-container transition-colors">
          <div class="mb-12 flex justify-between items-start">
            <span class="material-symbols-outlined text-3xl text-emerald-success">account_tree</span>
            <span class="mono-label text-text-muted">MOD_02</span>
          </div>
          <h4 class="mono-label text-lg text-text-primary mb-4">Namespace_Logic</h4>
          <p class="text-sm text-text-secondary leading-relaxed">Strongly typed schema definitions with built-in validation for relation tuples and usersets. Immutable versioning with automatic cycle detection.</p>
        </div>
        <div class="p-10 border-r border-b border-outline-variant group hover:bg-surface-container transition-colors">
          <div class="mb-12 flex justify-between items-start">
            <span class="material-symbols-outlined text-3xl text-emerald-success">terminal</span>
            <span class="mono-label text-text-muted">MOD_03</span>
          </div>
          <h4 class="mono-label text-lg text-text-primary mb-4">Check & Expand</h4>
          <p class="text-sm text-text-secondary leading-relaxed">Interactive tools for verifying authorization logic. Run checks, expand permissions, and debug resolution paths with full traversal visibility.</p>
        </div>
      </div>
    </section>

    <!-- Code Blueprint -->
    <section class="py-32 px-margin-page border-y border-outline-variant bg-surface-container-lowest">
      <div class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
        <div>
          <span class="mono-label text-emerald-success block mb-4">Implementation_Guide</span>
          <h3 class="font-headline-lg text-4xl font-extrabold tracking-tight-custom mb-8">Structured Logic Output.</h3>
          <p class="text-text-secondary mb-12 leading-relaxed">Define your authorization graph as a deterministic JSON schema. Zeval interprets relation tuples and rewrite rules to perform high-precision graph traversals — no bespoke if/else logic.</p>
          <div class="space-y-6">
            <div class="flex items-start gap-4 p-4 border border-outline-variant bg-background">
              <span class="mono-label text-emerald-success mt-1">✓</span>
              <div>
                <p class="mono-label text-text-primary">Multi_Tenant_Partitioning</p>
                <p class="text-xs text-text-secondary mt-1">Strict isolation of authorization data at the engine level. Every tenant is fully independent.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 border border-outline-variant bg-background">
              <span class="mono-label text-emerald-success mt-1">✓</span>
              <div>
                <p class="mono-label text-text-primary">Read_Your_Writes</p>
                <p class="text-xs text-text-secondary mt-1">Zookie-based consistency tokens ensure point-in-time snapshot reads across the graph.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 border border-outline-variant bg-background">
              <span class="mono-label text-emerald-success mt-1">✓</span>
              <div>
                <p class="mono-label text-text-primary">Six_Rule_Engine</p>
                <p class="text-xs text-text-secondary mt-1">Union, intersection, exclusion, computed_userset, tuple_to_userset, and direct this — compose them to model any policy.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="module-block overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 bg-background border-b border-outline-variant">
            <div class="flex gap-2">
              <div class="w-2 h-2 bg-outline"></div>
              <div class="w-2 h-2 bg-outline"></div>
              <div class="w-2 h-2 bg-outline"></div>
            </div>
            <span class="mono-label text-[9px] text-text-muted">src/auth/schema_v1.rebac</span>
          </div>
          <div class="p-8 font-code-block text-xs text-text-secondary leading-relaxed" style="background-color: #050505;">
            <%= code_block() %>
          </div>
          <div class="border-t border-outline-variant px-4 py-2 flex justify-between mono-label text-[9px] text-text-muted">
            <span>L: 28 C: 12</span>
            <span>UTF-8 // JSON</span>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="bg-black py-24 px-margin-page" style="background-color: #000000;">
    <div class="max-w-container-max mx-auto grid grid-cols-12 gap-16">
      <div class="col-span-12 md:col-span-4">
        <svg width="120" height="28" viewBox="0 0 400 100" fill="none" class="h-4 w-auto mb-8" style="opacity: 0.5;">
          <text x="0" y="70" font-family="Inter, sans-serif" font-weight="900" font-size="64" letter-spacing="0.1em" fill="#ffffff">ZEVAL</text>
          <rect x="300" y="45" width="40" height="4" fill="#10b981"/>
        </svg>
        <p class="text-xs text-text-muted leading-relaxed max-w-xs mb-8">
          High-precision Relationship-Based Access Control (ReBAC) for engineering-led organizations. Deterministic graph authorization at scale.
        </p>
      </div>
      <div class="col-span-12 md:col-span-8 grid grid-cols-2 sm:grid-cols-3 gap-12">
        <div class="flex flex-col gap-4">
          <span class="mono-label text-text-primary mb-2">01_Resources</span>
          <a href="/dashboard/docs" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">DOC_CORE</a>
          <a href="/dashboard/docs" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">API_REF</a>
          <a href="/dashboard/docs" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">GUIDE_SCHEMA</a>
        </div>
        <div class="flex flex-col gap-4">
          <span class="mono-label text-text-primary mb-2">02_Product</span>
          <a href="/dashboard/check" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">CHECK_API</a>
          <a href="/dashboard/namespaces/new" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">NAMESPACE_NEW</a>
          <a href="/dashboard/tenants" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">TENANTS</a>
        </div>
        <div class="flex flex-col gap-4">
          <span class="mono-label text-text-primary mb-2">03_Metadata</span>
          <a href="https://github.com/anomalyco/zeval_engine" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">SOURCE_CODE</a>
          <a href="https://github.com/anomalyco/zeval_engine/issues" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">ISSUES</a>
          <a href="/dashboard/docs" class="text-xs text-text-muted hover:text-emerald-success transition-colors mono-label">CHANGELOG</a>
        </div>
      </div>
    </div>
    <div class="max-w-container-max mx-auto mt-24 pt-8 border-t border-outline-variant flex flex-col sm:flex-row justify-between items-center gap-6" style="border-color: #1a1a1a;">
      <p class="mono-label text-[9px] text-text-muted">© 2024 ZEVAL_ENGINE. OPEN_SOURCE // MIT LICENSE.</p>
      <div class="flex gap-10 mono-label text-[9px] text-text-muted">
        <a href="https://github.com/anomalyco/zeval_engine" class="hover:text-text-primary">GITHUB_REPO</a>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.module-block, [class*="p-10 border-r"]').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(10px)';
        el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
        observer.observe(el);
    });
  </script>
</body>
</html>
